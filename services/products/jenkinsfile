pipeline {
    agent any

    tools {
        maven 'mvn'
    }

    stages {

stage('Check Changes') {
    steps {
        script {
            sh "git fetch origin main"

            def change = sh(
                script: "git diff --name-only origin/main HEAD | grep '^services/products/' || true",
                returnStdout: true
            ).trim()

            if (!change) {
                echo "No changes in products service. Skipping pipeline."
                currentBuild.result = 'NOT_BUILT'
                error("Skipping build - no relevant changes")
            }
        }
    }
}
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Prithvi333/Nexora.git'
            }
        }

        stage('Build JAR') {

            steps {
                dir('services/products') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {

            steps {
                dir('services/products') {
                    sh 'docker build -t prithvi069/nexora-products .'
                }
            }
        }

        stage('Push Docker Image') {

            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'docker-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push prithvi069/nexora-products
                        docker logout
                    '''
                }
            }
        }

        stage('Ensure Swarm') {
            steps {
                sh '''
                    if ! docker info | grep -i "Swarm: active"; then
                        echo "Initializing Swarm..."
                        docker swarm init
                        docker stack deploy -c docker-compose.yml nexora
                    else
                        echo "Swarm already active"
                    fi
                '''
            }
        }

        stage('Deploy Stack') {

            steps {
                sh '''
               docker service update --image prithvi069/nexora-products nexora_products
                '''
            }
        }
    }
}